[Version]
Signature="$WINDOWS NT$"
Class=Display
ClassGuid={4D36E968-E325-11CE-BFC1-08002BE10318}
Provider=%ProviderName%
CatalogFile=led_idd.cat
DriverVer=05/20/2026,0.1.0.0
PnpLockdown=1

[DestinationDirs]
UMDriverCopy=12,UMDF

[SourceDisksNames]
1=%DiskName%,,,""

[SourceDisksFiles]
led_idd.dll=1

[Manufacturer]
%ManufacturerName%=Standard,NTamd64

[Standard.NTamd64]
%DeviceName%=LedIdd_Install,Root\LedIdd

[LedIdd_Install.NT]
CopyFiles=UMDriverCopy

[LedIdd_Install.NT.hw]
AddReg=LedIdd_HardwareDeviceSettings

[UMDriverCopy]
led_idd.dll

[LedIdd_HardwareDeviceSettings]
HKR,,UpperFilters,%REG_MULTI_SZ%,"IndirectKmd"
HKR,"WUDF","DeviceGroupId",%REG_SZ%,"LedIddGroup"
HKR,,Security,,"D:P(A;;GA;;;BA)(A;;GA;;;SY)(A;;GA;;;UD)"

[LedIdd_Install.NT.Services]
AddService=WUDFRd,0x000001fa,WUDFRD_ServiceInstall

[WUDFRD_ServiceInstall]
DisplayName=%WudfRdDisplayName%
ServiceType=1
StartType=3
ErrorControl=1
ServiceBinary=%12%\WUDFRd.sys

[LedIdd_Install.NT.Wdf]
UmdfService=led_idd,led_idd_Install
UmdfServiceOrder=led_idd
UmdfKernelModeClientPolicy=AllowKernelModeClients

[led_idd_Install]
UmdfLibraryVersion=@LED_UMDF_VERSION@
ServiceBinary=%12%\UMDF\led_idd.dll
UmdfExtensions=IddCx0102

[Strings]
ProviderName="lan-extended-display"
ManufacturerName="lan-extended-display"
DeviceName="LED LAN Virtual Display Adapter"
DiskName="LED LAN Virtual Display Driver"
WudfRdDisplayName="Windows Driver Foundation - User-mode Driver Framework Reflector"
REG_MULTI_SZ=0x00010000
REG_SZ=0x00000000
